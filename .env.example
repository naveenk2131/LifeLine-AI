# =====================================================
# LifeLine AI — Environment Variables Template
# Copy this file to .env and fill in your actual keys.
# =====================================================

# OpenRouter API Key (OpenAI-compatible unified gateway)
# Get yours at: https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Twilio Account Credentials
# Get yours at: https://console.twilio.com/
TWILIO_ACCOUNT_SID=your_twilio_account_sid_here
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here

# Your Twilio phone number (E.164 format, e.g., +14155552671)
TWILIO_PHONE_NUMBER=+1XXXXXXXXXX
